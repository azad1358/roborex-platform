# Copy to docker/.env and replace every value with a real secret.
# In production this file lives only on the VM and is never uploaded by CD.
POSTGRES_DB=roborex
POSTGRES_USER=roborex
POSTGRES_PASSWORD=change-me
N8N_USER=admin
N8N_PASSWORD=change-me
N8N_HOST=n8n.example.com
WEBHOOK_URL=https://n8n.example.com/
GENERIC_TIMEZONE=Europe/Berlin
N8N_ENCRYPTION_KEY=change-me
MINIO_ROOT_USER=roborex
MINIO_ROOT_PASSWORD=change-me
